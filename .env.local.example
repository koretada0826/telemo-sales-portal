# このファイルは「Supabase等の外部設定時の見本」。
# 実際の値は .env.local にコピー（.gitignore済み）。

# --- 自前ログインのセッション署名鍵 ---
# ★必須：ランダムな長い文字列を設定。生成コマンド：
#   openssl rand -hex 32
# 本番デプロイ時は必ずVercel環境変数などで新しい値を設定すること。
SESSION_SECRET=

# --- Supabase（将来接続する場合） ---
# NEXT_PUBLIC_ が付く変数はブラウザに露出する。秘密キーは絶対に付けない
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（ブラウザに漏れない）
SUPABASE_SERVICE_ROLE_KEY=
